{
  "name": "taco-clicker",
  "version": "2.1.3",
  "description": "Taco Clicker Game",
  "author": "tacovr-12",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder build --win",
    "publish": "electron-builder --publish always",
    "release": "electron-builder build --win"
  },
  "build": {
    "appId": "com.tacovr12.tacoclicker",
    "productName": "Taco Clicker",
    "directories": {
      "output": "dist"
    },
    "publish": [{
      "provider": "github",
      "owner": "tacovr-12",
      "repo": "taco-clicker"
    }],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Taco Clicker"
    }
  },
  "dependencies": {
    "electron-updater": "^6.1.7"
  },
  "devDependencies": {
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1"
  }
}
