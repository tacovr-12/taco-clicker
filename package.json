{
  "name": "taco-clicker",
  "version": "2.1.0",
  "description": "Taco Clicker Game",
  "author": "tacovr-12",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "publish": "electron-builder --publish always",
    "release": "electron-builder --publish always"
  },
  "build": {
    "appId": "com.tacovr12.tacoclicker",
    "publish": [{
      "provider": "github",
      "owner": "tacovr-12",
      "repo": "taco-clicker",
      "releaseType": "release"
    }],
    "win": {
      "target": "nsis",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Super Taco Clicker"
    }
  },
  "dependencies": {
    "electron-updater": "^6.1.7"
  },
  "devDependencies": {
    "electron": "^36.2.1",
    "electron-builder": "^26.0.0"
  }
}
